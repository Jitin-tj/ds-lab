#include <stdio.h>
void Bsort(int *ptr, int n){
	int i,j;
	for(i=0;i<n;i++){
		for(j=0;j<n-i-1;j++){
			if(*(ptr+j) > *(ptr+j+1)){
				*(ptr+j+1) = *(ptr+j) + *(ptr+j+1);
				*(ptr+j) = *(ptr+j+1) - *(ptr+j);
				*(ptr+j+1) = *(ptr+j+1) - *(ptr+j);
			}
		}
	}
}
int main(){
	int ar[100],i,j,n;
	printf("enter the size of the array :");
	scanf("%d",&n);
	printf("enter the elements: ");
	for(i=0;i<n;i++){
		scanf("%d",&ar[i]);
	}
	Bsort(ar,n);
	for(i=0;i<n;i++){
                printf("%d\t",ar[i]);
        }
	printf("\n");
	return 0;
}
